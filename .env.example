# Aplicacion
APP_NAME=DataSacCore
APP_VERSION=0.1.0
APP_ENV=dev
CHECK_DATABASE_ON_STARTUP=true
CHECK_MONGO_ON_STARTUP=true

# CORS
# En APP_ENV=dev se permite cualquier origen automaticamente: *
# En otros ambientes usar una lista separada por comas.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQL Server principal
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=1433
DB_NAME=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=no
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_QUERY_TIMEOUT=30

# SQL Server secundario para provisiones vivas (SAC_PROVICIONES)
# Las variables vacias reutilizan su equivalente DB_* de la conexion principal.
# Completar solamente las ALT_DB_* cuya conexion sea diferente.
ALT_DB_USER=
ALT_DB_PASSWORD=
ALT_DB_HOST=
ALT_DB_PORT=
ALT_DB_NAME=SAC_PROVICIONES
ALT_DB_DRIVER=
ALT_DB_ENCRYPT=
ALT_DB_TRUST_SERVER_CERTIFICATE=
# El pool es independiente para no consumir el pool de la base principal.
ALT_DB_POOL_SIZE=10
ALT_DB_MAX_OVERFLOW=5
ALT_DB_POOL_TIMEOUT=30
ALT_DB_POOL_RECYCLE=1800
ALT_DB_QUERY_TIMEOUT=

# MongoDB
MONGO_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_LOGS_DB_NAME=logs
MONGO_DATASAC_DB_NAME=DataSac
MONGO_MAYOR_AUXILIAR_DB_NAME=MayorAuxiliar
MONGO_ANALYTIC_SAC_DB_NAME=AnalyticSac

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=180
